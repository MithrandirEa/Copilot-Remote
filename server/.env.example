# =============================================================================
# Copilot Remote Bridge v2 — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles.
# NE JAMAIS committer .env dans Git.
# =============================================================================

# --- Authentification WebSocket ---
# Token partagé entre tous les clients (extension VS Code + navigateur mobile).
# Générer avec : openssl rand -hex 32
# Ce token est transmis dans le premier message WebSocket (jamais dans l'URL).
AUTH_SECRET_TOKEN=remplacer_par_votre_secret_64_chars_hex

# --- Serveur ---
# Niveau de log uvicorn (debug | info | warning | error | critical)
# En production : warning ou error pour éviter de logguer les messages WS.
LOG_LEVEL=warning

# Environnement (development | production)
ENVIRONMENT=production

# --- Note : HOST et PORT ---
# L'hôte (0.0.0.0) et le port (8765) sont définis directement dans le Dockerfile.
# Ils ne sont pas configurables via .env — modifier le Dockerfile si nécessaire.
# Le port 8765 n'est pas exposé sur l'hôte : Caddy sert de reverse proxy.
